{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wheelhouse.dev/schemas/agent-runtime/v1alpha1/agent-task.schema.json",
  "title": "Wheelhouse AgentTask v1alpha1",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": {"const": "wheelhouse.agent-runtime/v1alpha1"},
    "kind": {"const": "AgentTask"},
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["executionId", "action", "idempotencyKey", "wheelhouseRevision", "target"],
      "properties": {
        "executionId": {"type": "string", "pattern": "^[0-9a-f-]{36}$"},
        "action": {"type": "string", "enum": ["triage.issue.local", "triage.issue.search", "triage.pr.local", "triage.pr.search", "triage.schema-repair", "deep-review.local", "deep-review.search", "nl-decision.local", "nl-decision.search", "nl-decision.schema-repair"]},
        "idempotencyKey": {"type": "string", "minLength": 1, "maxLength": 512},
        "wheelhouseRevision": {"type": "string", "pattern": "^[0-9A-Fa-f]{7,64}$"},
        "sourceReview": {
          "type": "object",
          "additionalProperties": false,
          "required": ["baseSha", "visionSha", "visionContentSha256", "targetRepositoryCommit"],
          "properties": {
            "baseSha": {"type": "string", "pattern": "^[0-9A-Fa-f]{7,64}$"},
            "visionSha": {"type": "string", "pattern": "^[0-9A-Fa-f]{7,64}$"},
            "visionContentSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
            "targetRepositoryCommit": {"type": "string", "pattern": "^[0-9a-f]{40}$"}
          }
        },
        "target": {
          "type": "object",
          "additionalProperties": false,
          "required": ["owner", "repo", "number", "kind", "revision"],
          "properties": {
            "owner": {"type": "string", "pattern": "^[A-Za-z0-9_.-]+$"},
            "repo": {"type": "string", "pattern": "^[A-Za-z0-9_.-]+$"},
            "number": {"type": "integer", "minimum": 1},
            "kind": {"type": "string", "enum": ["pr-review", "issue-triage", "ci-approval", "schema-repair"]},
            "revision": {"type": "string", "minLength": 1, "maxLength": 128}
          }
        }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["selection", "prompt", "inputs", "capabilities", "tools", "isolation", "limits", "output", "retry", "session", "retention"],
      "properties": {
        "selection": {
          "type": "object",
          "additionalProperties": false,
          "required": ["profile", "candidates", "fallback"],
          "properties": {
            "profile": {"type": "string", "minLength": 1},
            "candidates": {
              "type": "array", "minItems": 1, "maxItems": 8,
              "items": {
                "type": "object", "additionalProperties": false,
                "required": ["harness", "adapter", "provider", "authProfile", "authMechanism", "expectedWorkspaceId", "model", "effort", "costClass", "dataBoundary", "allowModelAlias"],
                "properties": {
                  "harness": {"type": "string", "minLength": 1},
                  "adapter": {"type": "string", "minLength": 1},
                  "provider": {"type": "string", "minLength": 1},
                  "authProfile": {"type": "string", "minLength": 1},
                  "authMechanism": {"type": "string", "enum": ["claude-action-oauth", "claude-code-oauth-token", "codex-access-token", "managed-auth-json", "fake"]},
                  "expectedWorkspaceId": {"type": ["string", "null"], "maxLength": 160},
                  "model": {"type": "string", "minLength": 1},
                  "effort": {"type": "string", "minLength": 1},
                  "costClass": {"type": "string", "enum": ["subscription", "metered", "unknown"]},
                  "dataBoundary": {"type": "string", "minLength": 1},
                  "allowModelAlias": {"type": "boolean"}
                }
              }
            },
            "fallback": {
              "type": "object", "additionalProperties": false,
              "required": ["mode"],
              "properties": {"mode": {"const": "none"}}
            }
          }
        },
        "prompt": {
          "type": "object", "additionalProperties": false,
          "required": ["system", "userArtifact", "segments"],
          "properties": {
            "system": {
              "type": "object", "additionalProperties": false,
              "required": ["mode", "adapterShimVersion", "adapterShimSha256"],
              "properties": {
                "mode": {"type": "string", "enum": ["native-default-plus-core", "replace", "append"]},
                "adapterShimVersion": {"type": "string", "minLength": 1},
                "adapterShimSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
              }
            },
            "userArtifact": {"type": "string", "pattern": "^artifacts/sha256/[0-9a-f]{64}$"},
            "segments": {
              "type": "array", "minItems": 1, "maxItems": 32,
              "items": {
                "type": "object", "additionalProperties": false,
                "required": ["name", "trust", "origin", "sha256", "bytes"],
                "properties": {
                  "name": {"type": "string", "minLength": 1, "maxLength": 80},
                  "trust": {"type": "string", "enum": ["trusted", "untrusted"]},
                  "origin": {"type": "string", "minLength": 1, "maxLength": 80},
                  "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
                  "bytes": {"type": "integer", "minimum": 0},
                  "artifact": {"type": "string", "pattern": "^artifacts/sha256/[0-9a-f]{64}$"}
                }
              }
            }
          }
        },
        "inputs": {
          "type": "array", "maxItems": 16,
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["id", "artifact", "logicalPath", "sha256", "mediaType", "trust", "mount", "maxBytes", "bytes"],
            "properties": {
              "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]{0,63}$"},
              "artifact": {"type": "string", "pattern": "^artifacts/sha256/[0-9a-f]{64}$"},
              "logicalPath": {"type": "string", "pattern": "^[A-Za-z0-9_.-]+(?:/[A-Za-z0-9_.-]+)*$"},
              "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
              "mediaType": {"type": "string", "minLength": 1},
              "trust": {"type": "string", "enum": ["trusted", "untrusted"]},
              "mount": {"const": "read-only"},
              "maxBytes": {"type": "integer", "minimum": 0, "maximum": 250000000},
              "bytes": {"type": "integer", "minimum": 0, "maximum": 250000000},
              "git": {
                "type": "object", "additionalProperties": false,
                "required": ["commit", "detached", "fileCount", "treeSha256", "symlinkCount", "symlinkProvenanceArtifact", "symlinkProvenanceSha256"],
                "properties": {
                  "commit": {"type": "string", "pattern": "^[0-9A-Fa-f]{7,64}$"},
                  "detached": {"const": true},
                  "fileCount": {"type": "integer", "minimum": 0},
                  "treeSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
                  "symlinkCount": {"type": "integer", "minimum": 0, "maximum": 4096},
                  "symlinkProvenanceArtifact": {"type": "string", "pattern": "^artifacts/sha256/[0-9a-f]{64}$"},
                  "symlinkProvenanceSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
                }
              }
            }
          }
        },
        "capabilities": {"$ref": "#/$defs/capabilityRequest"},
        "tools": {
          "type": "object", "additionalProperties": false,
          "required": ["default", "parallel", "tools"],
          "properties": {
            "default": {"const": "deny"},
            "parallel": {"const": false},
            "tools": {
              "type": "array", "maxItems": 8,
              "items": {
                "type": "object", "additionalProperties": false,
                "required": ["name", "version", "maxResultBytes", "inputSchemaSha256"],
                "properties": {
                  "name": {"type": "string", "enum": ["fs.read", "fs.grep", "fs.glob", "github.search.readonly", "final.triage", "final.nl-decision", "final.deep-review", "final.schema-repair"]},
                  "version": {"const": 1},
                  "maxResultBytes": {"type": "integer", "minimum": 1, "maximum": 131072},
                  "inputSchemaSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
                  "terminating": {"type": "boolean"}
                }
              }
            }
          }
        },
        "isolation": {
          "type": "object", "additionalProperties": false,
          "required": ["profile", "worker", "rootFilesystem", "writableRoots", "modelNetwork", "toolNetwork", "inheritEnvironment", "dropCapabilities", "noNewPrivileges", "denyHostHome"],
          "properties": {
            "profile": {"type": "string", "enum": ["sandboxed-worker-v1", "claude-artifact-bridge-v1"]},
            "worker": {"type": "string", "enum": ["sandboxed-adapter-worker", "separate-read-only-github-job"]},
            "rootFilesystem": {"type": "string", "enum": ["read-only", "verified-artifact-workspace"]},
            "writableRoots": {"type": "array", "items": {"type": "string"}, "maxItems": 4},
            "modelNetwork": {
              "type": "object", "additionalProperties": false,
              "required": ["mode", "allowedHosts"],
              "properties": {
                "mode": {"type": "string", "enum": ["provider-only", "runner-default"]},
                "allowedHosts": {"type": "array", "maxItems": 16, "items": {"type": "string", "pattern": "^[A-Za-z0-9.-]+$"}}
              }
            },
            "toolNetwork": {"type": "object", "additionalProperties": false, "required": ["mode"], "properties": {"mode": {"type": "string", "enum": ["none", "broker-only", "runner-default"]}}},
            "inheritEnvironment": {"type": "boolean"},
            "dropCapabilities": {"type": "boolean"},
            "noNewPrivileges": {"type": "boolean"},
            "denyHostHome": {"type": "boolean"}
          }
        },
        "limits": {
          "type": "object", "additionalProperties": false,
          "required": ["softDeadlineMs", "hardDeadlineMs", "dispatchDeadlineMs", "childExecutionTimeoutMs", "cancelGraceMs", "maxTurns", "maxToolCalls", "maxFinalBytes", "maxEventBytes", "maxProviderRequests", "maxInputTokens", "maxOutputTokens", "enforcement"],
          "properties": {
            "softDeadlineMs": {"type": ["integer", "null"], "minimum": 1000, "maximum": 3600000},
            "hardDeadlineMs": {"type": ["integer", "null"], "minimum": 1000, "maximum": 3600000},
            "dispatchDeadlineMs": {"type": ["integer", "null"], "minimum": 1000, "maximum": 300000},
            "childExecutionTimeoutMs": {"type": ["integer", "null"], "minimum": 60000, "maximum": 3600000},
            "cancelGraceMs": {"type": ["integer", "null"], "minimum": 100, "maximum": 60000},
            "maxTurns": {"type": ["integer", "null"], "minimum": 1, "maximum": 128},
            "maxToolCalls": {"type": ["integer", "null"], "minimum": 0, "maximum": 512},
            "maxFinalBytes": {"type": "integer", "minimum": 1, "maximum": 131072},
            "maxEventBytes": {"type": "integer", "minimum": 1024, "maximum": 16777216},
            "maxProviderRequests": {"type": ["integer", "null"], "minimum": 1, "maximum": 128},
            "maxInputTokens": {"type": ["integer", "null"], "minimum": 1, "maximum": 1000000},
            "maxOutputTokens": {"type": ["integer", "null"], "minimum": 1, "maximum": 131072},
            "enforcement": {
              "type": "object", "additionalProperties": false,
              "required": ["softDeadlineMs", "hardDeadlineMs", "dispatchDeadlineMs", "childExecutionTimeoutMs", "cancelGraceMs", "maxTurns", "maxToolCalls", "maxFinalBytes", "maxEventBytes", "maxProviderRequests", "maxInputTokens", "maxOutputTokens"],
              "properties": {
                "softDeadlineMs": {"$ref": "#/$defs/limitEnforcement"},
                "hardDeadlineMs": {"$ref": "#/$defs/limitEnforcement"},
                "dispatchDeadlineMs": {"$ref": "#/$defs/limitEnforcement"},
                "childExecutionTimeoutMs": {"$ref": "#/$defs/limitEnforcement"},
                "cancelGraceMs": {"$ref": "#/$defs/limitEnforcement"},
                "maxTurns": {"$ref": "#/$defs/limitEnforcement"},
                "maxToolCalls": {"$ref": "#/$defs/limitEnforcement"},
                "maxFinalBytes": {"$ref": "#/$defs/limitEnforcement"},
                "maxEventBytes": {"$ref": "#/$defs/limitEnforcement"},
                "maxProviderRequests": {"$ref": "#/$defs/limitEnforcement"},
                "maxInputTokens": {"$ref": "#/$defs/limitEnforcement"},
                "maxOutputTokens": {"$ref": "#/$defs/limitEnforcement"}
              }
            }
          }
        },
        "output": {
          "type": "object", "additionalProperties": false,
          "required": ["schemaArtifact", "schemaId", "schemaSha256", "evidencePolicy", "allowProseFallback"],
          "properties": {
            "schemaArtifact": {"type": "string", "pattern": "^artifacts/sha256/[0-9a-f]{64}$"},
            "schemaId": {"type": "string", "minLength": 1},
            "schemaSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
            "evidencePolicy": {"type": "string", "enum": ["target-anchor/v1", "none"]},
            "allowProseFallback": {"const": false}
          }
        },
        "retry": {
          "type": "object", "additionalProperties": false,
          "required": ["sameCandidateMaxAttempts", "retryable", "repairTask"],
          "properties": {
            "sameCandidateMaxAttempts": {"const": 1},
            "retryable": {"type": "array", "maxItems": 0},
            "repairTask": {"type": ["string", "null"]}
          }
        },
        "session": {"type": "object", "additionalProperties": false, "required": ["mode", "resume"], "properties": {"mode": {"const": "ephemeral"}, "resume": {"const": "forbidden"}}},
        "retention": {
          "type": "object", "additionalProperties": false,
          "required": ["normalizedEventsDays", "rawTranscript", "finalResult", "redactionPolicy"],
          "properties": {
            "normalizedEventsDays": {"type": "integer", "minimum": 0, "maximum": 30},
            "rawTranscript": {"type": "string", "enum": ["discard", "transient-cross-job"]},
            "finalResult": {"const": "consumer-owned"},
            "redactionPolicy": {"const": "wheelhouse-agent/v1"}
          }
        }
      }
    }
  },
  "$defs": {
    "limitEnforcement": {"type": "string", "enum": ["externally-enforced", "adapter-enforced", "unavailable"]},
    "capability": {
      "type": "object", "additionalProperties": false,
      "required": ["name", "constraints"],
      "properties": {"name": {"type": "string", "minLength": 1}, "constraints": {"type": "object"}}
    },
    "capabilityRequest": {
      "type": "object", "additionalProperties": false,
      "required": ["required", "optional"],
      "properties": {
        "required": {"type": "array", "minItems": 1, "maxItems": 32, "items": {"$ref": "#/$defs/capability"}},
        "optional": {"type": "array", "maxItems": 32, "items": {"$ref": "#/$defs/capability"}}
      }
    }
  }
}
