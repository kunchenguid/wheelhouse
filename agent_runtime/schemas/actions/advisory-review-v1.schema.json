{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "wheelhouse/advisory-review/v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "result_kind",
    "policy_derivation",
    "coverage_audit",
    "verdict",
    "summary",
    "obligation_results",
    "citations",
    "limitations",
    "requested_evidence"
  ],
  "properties": {
    "result_kind": {"type": "string", "const": "AdvisoryReview"},
    "policy_derivation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "vision_sha256", "units", "obligations"],
      "properties": {
        "version": {"type": "string", "const": "wheelhouse/evidence-plan/v2"},
        "vision_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "units": {
          "type": "array", "maxItems": 128,
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["unit_id", "start_line", "end_line", "text", "sha256", "classification", "semantic_status"],
            "properties": {
              "unit_id": {"type": "string", "pattern": "^P[0-9]{3}$"},
              "start_line": {"type": "integer", "minimum": 1},
              "end_line": {"type": "integer", "minimum": 1},
              "text": {"type": "string", "minLength": 1, "maxLength": 40000},
              "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
              "classification": {"type": "string", "enum": ["context-only", "decision-criterion", "evidence-obligation"]},
              "semantic_status": {"type": "string", "enum": ["recognized", "recognized-local", "unknown", "ambiguous"]}
            }
          }
        },
        "obligations": {
          "type": "array", "maxItems": 128,
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["obligation_id", "unit_id", "operation", "required", "requirement", "semantic_status"],
            "properties": {
              "obligation_id": {"type": "string", "pattern": "^O[0-9]{3}$"},
              "unit_id": {"type": "string", "pattern": "^P[0-9]{3}$"},
              "operation": {"type": "string", "enum": ["public.git_snapshot", "public.fetch", "public.artifact", "digest.verify", "exercise.run", "policy.assess"]},
              "required": {"type": "boolean"},
              "requirement": {"type": "string", "minLength": 1, "maxLength": 40000},
              "semantic_status": {"type": "string", "enum": ["recognized", "recognized-local", "unknown", "ambiguous"]},
              "expected_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
            }
          }
        }
      }
    },
    "coverage_audit": {
      "type": "object", "additionalProperties": false,
      "required": ["version", "vision_sha256", "units", "obligations", "complete", "disagreements"],
      "properties": {
        "version": {"type": "string", "const": "wheelhouse/evidence-plan-audit/v1"},
        "vision_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "units": {
          "type": "array", "maxItems": 128,
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["unit_id", "sha256", "classification", "semantic_status", "complete"],
            "properties": {
              "unit_id": {"type": "string", "pattern": "^P[0-9]{3}$"},
              "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
              "classification": {"type": "string", "enum": ["context-only", "decision-criterion", "evidence-obligation"]},
              "semantic_status": {"type": "string", "enum": ["recognized", "recognized-local", "unknown", "ambiguous"]},
              "complete": {"type": "boolean"}
            }
          }
        },
        "obligations": {
          "type": "array", "maxItems": 128,
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["obligation_id", "unit_id", "operation", "required", "semantic_status", "complete"],
            "properties": {
              "obligation_id": {"type": "string", "pattern": "^O[0-9]{3}$"},
              "unit_id": {"type": "string", "pattern": "^P[0-9]{3}$"},
              "operation": {"type": "string", "enum": ["public.git_snapshot", "public.fetch", "public.artifact", "digest.verify", "exercise.run", "policy.assess"]},
              "required": {"type": "boolean"},
              "semantic_status": {"type": "string", "enum": ["recognized", "recognized-local", "unknown", "ambiguous"]},
              "complete": {"type": "boolean"}
            }
          }
        },
        "complete": {"type": "boolean"},
        "disagreements": {"type": "array", "maxItems": 128, "items": {"type": "string", "minLength": 1, "maxLength": 2000}}
      }
    },
    "verdict": {"type": "string", "enum": ["positive", "negative", "inconclusive"]},
    "summary": {"type": "string", "minLength": 1, "maxLength": 8000},
    "obligation_results": {
      "type": "array",
      "maxItems": 128,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["obligation_id", "assessment", "rationale", "citation_ids"],
        "properties": {
          "obligation_id": {"type": "string", "pattern": "^O[0-9]{3}$"},
          "assessment": {"type": "string", "enum": ["pass", "fail", "unavailable", "not_applicable"]},
          "rationale": {"type": "string", "minLength": 1, "maxLength": 4000},
          "citation_ids": {
            "type": "array",
            "maxItems": 32,
            "items": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
          }
        }
      }
    },
    "citations": {
      "type": "array",
      "maxItems": 256,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["evidence_id", "location", "claim"],
        "properties": {
          "evidence_id": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "location": {"type": "string", "minLength": 1, "maxLength": 1000},
          "claim": {"type": "string", "minLength": 1, "maxLength": 2000}
        }
      }
    },
    "limitations": {
      "type": "array",
      "maxItems": 64,
      "items": {"type": "string", "minLength": 1, "maxLength": 2000}
    },
    "requested_evidence": {
      "type": "array",
      "maxItems": 64,
      "items": {"type": "string", "minLength": 1, "maxLength": 2000}
    },
    "eligibility_facts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "behavior_class",
        "changes_existing_or_default_behavior",
        "optin_default_off",
        "aligns_with_vision",
        "recommendation"
      ],
      "properties": {
        "behavior_class": {"type": "string", "enum": ["A", "B", "C", "ineligible"]},
        "changes_existing_or_default_behavior": {"type": "boolean"},
        "optin_default_off": {"type": "boolean"},
        "aligns_with_vision": {"type": "boolean"},
        "recommendation": {"type": "string", "enum": ["eligible", "hold"]}
      }
    }
  }
}
