{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "wheelhouse/nl-decision/v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["mode"],
  "properties": {
    "mode": {"type": "string", "enum": ["action", "answer", "clarify"]},
    "action": {"type": "string", "maxLength": 80},
    "free_text": {"type": "string", "maxLength": 32768},
    "answer": {"type": "string", "maxLength": 65536}
  }
}
