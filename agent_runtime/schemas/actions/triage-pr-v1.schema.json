{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "wheelhouse/triage-pr/v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["summary", "product_implications", "recommended_action", "recommended_reason", "evidence"],
  "properties": {
    "summary": {"type": "string", "minLength": 1, "maxLength": 4000},
    "product_implications": {"type": "string", "minLength": 1, "maxLength": 4000},
    "recommended_action": {"type": "string", "enum": ["merge", "request-changes", "decline", "close", "hold", "investigate", "comment"]},
    "recommended_reason": {"type": "string", "minLength": 1, "maxLength": 4000},
    "evidence": {"type": "string", "minLength": 1, "maxLength": 8000},
    "vision_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_owner", "target_repo", "target_number", "target_facts_sha256", "vision_sha", "vision_content_sha256", "base_sha", "target_head_sha", "applicable_criteria"],
      "properties": {
        "target_owner": {"type": "string", "minLength": 1, "maxLength": 100},
        "target_repo": {"type": "string", "minLength": 1, "maxLength": 100},
        "target_number": {"type": "integer", "minimum": 1},
        "target_facts_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "vision_sha": {"type": "string", "pattern": "^[0-9a-f]{7,64}$"},
        "vision_content_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "base_sha": {"type": "string", "pattern": "^[0-9a-f]{7,64}$"},
        "target_head_sha": {"type": "string", "pattern": "^[0-9a-f]{7,64}$"},
        "applicable_criteria": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "quote", "external_source_required"],
            "properties": {
              "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$"},
              "quote": {"type": "string", "minLength": 8, "maxLength": 500},
              "external_source_required": {"type": "boolean"}
            }
          }
        }
      }
    },
    "source_provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "requested_ref", "resolved_commit", "inspected_files"],
      "properties": {
        "url": {"type": "string", "minLength": 1, "maxLength": 2048},
        "requested_ref": {"type": "string", "minLength": 1, "maxLength": 255},
        "resolved_commit": {"type": "string", "pattern": "^[0-9a-f]{40,64}$"},
        "inspected_files": {
          "type": "array",
          "minItems": 1,
          "maxItems": 128,
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "sha256"],
            "properties": {
              "path": {"type": "string", "minLength": 1, "maxLength": 1024},
              "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
            }
          }
        }
      }
    },
    "automerge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["behavior_class", "changes_existing_or_default_behavior", "optin_default_off"],
      "properties": {
        "behavior_class": {"type": "string", "enum": ["A", "B", "C", "ineligible"]},
        "external_source_required": {"type": "boolean"},
        "aligns_with_vision": {"type": "boolean"},
        "changes_existing_or_default_behavior": {"type": "boolean"},
        "optin_default_off": {"type": "boolean"},
        "recommend_merge": {"type": "boolean"}
      }
    }
  }
}
